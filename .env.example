# ── Provider selection ──────────────────────────────────────────────
# Options: groq | ollama | anthropic
# Groq is recommended for free open-source usage (Llama 3.3 70B)
LLM_PROVIDER=groq

# ── Groq (free) ─────────────────────────────────────────────────────
# Get a free key at https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here
# Default model — change to: mixtral-8x7b-32768 / llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (local, no key needed) ───────────────────────────────────
# Run: ollama pull llama3.1 && ollama serve
# OLLAMA_MODEL=llama3.1
# OLLAMA_BASE_URL=http://localhost:11434

# ── Anthropic Claude (paid) ─────────────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Optional: news / enhanced data ──────────────────────────────────
# NEWSAPI_KEY=your_newsapi_key_here
